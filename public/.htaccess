# eDrive Water Sports Next.js production rules
RewriteEngine On

# Use one canonical host for the current Next.js website.
RewriteCond %{HTTP_HOST} ^www\.edrivedubai\.ae$ [NC]
RewriteRule ^ https://edrivedubai.ae%{REQUEST_URI} [R=301,L]

# Protect environment and repository files if they are ever uploaded accidentally.
<FilesMatch "^(\.env|\.git|package(-lock)?\.json|tsconfig\.json)$">
  Require all denied
</FilesMatch>

<IfModule mod_setenvif.c>
  SetEnvIf Request_URI "^/_next/static/" edrive_versioned_asset=1
</IfModule>

<IfModule mod_headers.c>
  # Always revalidate HTML after a deployment.
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Only hashed Next.js assets receive long immutable caching.
  Header set Cache-Control "public, max-age=31536000, immutable" env=edrive_versioned_asset

  # The service worker must always be checked for updates.
  <Files "sw.js">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Service-Worker-Allowed "/"
  </Files>

  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>
